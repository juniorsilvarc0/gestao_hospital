# syntax=docker/dockerfile:1.7
# ─────────────────────────────────────────────────────────────────────
# HMS-BR AI Service (FastAPI) — Python 3.12.
# OCR (Tesseract/PaddleOCR) e NLP. Desativado por padrão no compose;
# entra em uso a partir da Fase 11.
# ─────────────────────────────────────────────────────────────────────

FROM python:3.12-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# System deps mínimas para OCR (Tesseract) e libs gráficas usadas por OpenCV/Pillow.
RUN apt-get update && apt-get install -y --no-install-recommends \
        tesseract-ocr \
        libgl1 \
        libglib2.0-0 \
        curl \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Instala em modo editável a partir do pyproject (placeholder até Fase 11).
COPY pyproject.toml ./
RUN pip install --upgrade pip \
    && pip install -e . \
    && pip install "fastapi>=0.115" "uvicorn[standard]>=0.32"

# Código fonte (ainda placeholder).
COPY . .

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=5 \
    CMD curl -fsS http://localhost:8000/healthz || exit 1

CMD ["uvicorn", "hms_ai_service.main:app", "--host", "0.0.0.0", "--port", "8000"]
