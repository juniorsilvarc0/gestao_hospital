# HMS-BR — apps/web/.dockerignore
# Mantém o build context da Web enxuto.

# Node / pnpm
node_modules
**/node_modules
.pnpm-store
.turbo
*.tsbuildinfo

# Builds e artefatos Vite/React
dist
build
coverage
*.log

# VCS
.git
.gitignore
.gitattributes

# Env (usar env_file no compose, não embutir na imagem)
.env
.env.*
!.env.example

# Python (defesa em profundidade)
__pycache__
*.pyc
.venv
venv

# Editores / SO
.vscode
.idea
.DS_Store
Thumbs.db
