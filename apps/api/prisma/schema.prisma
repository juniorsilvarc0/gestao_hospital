  uuid_externo     String             @unique(map: "uq_equipamentos_uuid") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenant_id        BigInt
  setor_id         BigInt?
  codigo           String             @db.VarChar(40)
  nome             String             @db.VarChar(200)
  tipo             String?            @db.VarChar(50)
  modelo           String?            @db.VarChar(120)
  serial           String?            @db.VarChar(60)
  status           String             @default("DISPONIVEL") @db.VarChar(30)
  ativo            Boolean            @default(true)
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?          @db.Timestamptz(6)
  deleted_at       DateTime?          @db.Timestamptz(6)
  agendas_recursos agendas_recursos[]
  setores          setores?           @relation(fields: [setor_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  tenants          Tenant             @relation(fields: [tenant_id], references: [id], onUpdate: NoAction)

  @@unique([tenant_id, codigo], map: "uq_equipamentos")
}

