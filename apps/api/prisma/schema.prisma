generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  extensions        = [btree_gin, btree_gist, pg_trgm, pgcrypto, unaccent, uuid_ossp(map: "uuid-ossp")]
}

model Tenant {
  id                    BigInt                  @id @default(autoincrement())
  uuidExterno           String                  @default(dbgenerated("uuid_generate_v4()")) @map("uuid_externo") @db.Uuid
  cnpj                  String                  @unique @db.VarChar(18)
  razaoSocial           String                  @map("razao_social") @db.VarChar(300)
  nomeFantasia          String?                 @map("nome_fantasia") @db.VarChar(300)
  cnes                  String?                 @db.VarChar(20)
  registroAns           String?                 @map("registro_ans") @db.VarChar(20)
  configuracoes         Json                    @default("{}")
  versaoTissPadrao      String                  @default("4.01.00") @map("versao_tiss_padrao") @db.VarChar(10)
  ativo                 Boolean                 @default(true)
  createdAt             DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime?               @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt             DateTime?               @map("deleted_at") @db.Timestamptz(6)
  codigo                String                  @unique(map: "uq_tenants_codigo") @db.VarChar(20)
  centros_custo         centros_custo[]
  condicoes_contratuais condicoes_contratuais[]
  convenios             convenios[]
  especialidades        especialidades[]
  leitos                leitos[]
  mfa_recovery_codes    MfaRecoveryCode[]
  pacientes             pacientes[]
  pacientes_convenios   pacientes_convenios[]
  perfis                Perfil[]
  planos                planos[]
  prestadores           prestadores[]
  salas_cirurgicas      salas_cirurgicas[]
  setores               setores[]
  tabelas_precos        tabelas_precos[]
  tabelas_procedimentos tabelas_procedimentos[]
  unidades_atendimento  unidades_atendimento[]
  unidades_faturamento  unidades_faturamento[]
  usuarios              Usuario[]

  @@index([codigo], map: "ix_tenants_codigo")
  @@map("tenants")
}

model Usuario {
  id                 BigInt               @id @default(autoincrement())
  uuidExterno        String               @default(dbgenerated("uuid_generate_v4()")) @map("uuid_externo") @db.Uuid
  tenantId           BigInt               @map("tenant_id")
  email              String               @db.VarChar(200)
  senhaHash          String?              @map("senha_hash") @db.VarChar(255)
  mfaSecret          String?              @map("mfa_secret") @db.VarChar(255)
  mfaHabilitado      Boolean              @default(false) @map("mfa_habilitado")
  prestadorId        BigInt?              @map("prestador_id")
  nome               String               @db.VarChar(300)
  ativo              Boolean              @default(true)
  ultimoLoginEm      DateTime?            @map("ultimo_login_em") @db.Timestamptz(6)
  ultimoLoginIp      String?              @map("ultimo_login_ip") @db.Inet
  tentativasLogin    Int                  @default(0) @map("tentativas_login")
  bloqueadoAte       DateTime?            @map("bloqueado_ate") @db.Timestamptz(6)
  precisaTrocarSenha Boolean              @default(true) @map("precisa_trocar_senha")
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime?            @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?            @map("deleted_at") @db.Timestamptz(6)
  acessos_prontuario acessos_prontuario[]
  mfaRecoveryCodes   MfaRecoveryCode[]
  sessoesAtivas      SessaoAtiva[]
  usuario_setores    usuario_setores[]
  prestadores        prestadores?         @relation(fields: [prestadorId], references: [id], onUpdate: NoAction, map: "fk_usuarios_prestador_id")
  tenant             Tenant               @relation(fields: [tenantId], references: [id], map: "fk_usuarios_tenant_id")
  perfis             UsuarioPerfil[]

  @@unique([tenantId, email], map: "uq_usuarios_email_tenant")
  @@index([tenantId], map: "ix_usuarios_tenant")
  @@index([prestadorId], map: "ix_usuarios_prestador")
  @@map("usuarios")
}

model Perfil {
  id         BigInt            @id @default(autoincrement())
  tenantId   BigInt            @map("tenant_id")
  codigo     String            @db.VarChar(50)
  nome       String            @db.VarChar(120)
  descricao  String?           @db.VarChar(500)
  ativo      Boolean           @default(true)
  tenant     Tenant            @relation(fields: [tenantId], references: [id], map: "fk_perfis_tenant_id")
  permissoes PerfilPermissao[]
  usuarios   UsuarioPerfil[]

  @@unique([tenantId, codigo], map: "uq_perfis_codigo_tenant")
  @@map("perfis")
}

model Permissao {
  id        BigInt            @id @default(autoincrement())
  recurso   String            @db.VarChar(80)
  acao      String            @db.VarChar(40)
  descricao String?           @db.VarChar(300)
  perfis    PerfilPermissao[]

  @@unique([recurso, acao], map: "uq_permissoes")
  @@map("permissoes")
}

model UsuarioPerfil {
  usuarioId BigInt  @map("usuario_id")
  perfilId  BigInt  @map("perfil_id")
  perfil    Perfil  @relation(fields: [perfilId], references: [id], onDelete: Cascade, map: "fk_usuarios_perfis_perfil_id")
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade, map: "fk_usuarios_perfis_usuario_id")

  @@id([usuarioId, perfilId])
  @@map("usuarios_perfis")
}

model PerfilPermissao {
  perfilId    BigInt    @map("perfil_id")
  permissaoId BigInt    @map("permissao_id")
  perfil      Perfil    @relation(fields: [perfilId], references: [id], onDelete: Cascade, map: "fk_perfis_permissoes_perfil_id")
  permissao   Permissao @relation(fields: [permissaoId], references: [id], onDelete: Cascade, map: "fk_perfis_permissoes_permissao_id")

  @@id([perfilId, permissaoId])
  @@map("perfis_permissoes")
}

model SessaoAtiva {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  usuarioId        BigInt    @map("usuario_id")
  refreshTokenHash String    @map("refresh_token_hash") @db.VarChar(255)
  ip               String?   @db.Inet
  userAgent        String?   @map("user_agent")
  expiraEm         DateTime  @map("expira_em") @db.Timestamptz(6)
  revogadaEm       DateTime? @map("revogada_em") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  usuario          Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, map: "fk_sessoes_ativas_usuario_id")

  @@index([usuarioId], map: "ix_sessoes_usuario")
  @@map("sessoes_ativas")
}

model MfaRecoveryCode {
  id        BigInt    @id @default(autoincrement())
  tenantId  BigInt    @map("tenant_id")
  usuarioId BigInt    @map("usuario_id")
  codeHash  String    @map("code_hash") @db.VarChar(255)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  tenants   Tenant    @relation(fields: [tenantId], references: [id], onUpdate: NoAction, map: "fk_mfa_recovery_codes_tenant_id")
  usuario   Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_mfa_recovery_codes_usuario_id")

  @@index([tenantId], map: "ix_mfa_rc_tenant")
  @@map("mfa_recovery_codes")
}

/// This table is a partition table and requires additional setup for migrations. Visit https://pris.ly/d/partition-tables for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model acessos_prontuario {
  id             BigInt    @default(autoincrement())
  tenant_id      BigInt
  paciente_id    BigInt
  atendimento_id BigInt?
  usuario_id     BigInt
  perfil         String    @db.VarChar(50)
  finalidade     String    @db.VarChar(200)
  modulo         String    @db.VarChar(50)
  ip             String?   @db.Inet
  acessado_em    DateTime  @default(now()) @db.Timestamptz(6)
  pacientes      pacientes @relation(fields: [paciente_id], references: [id], onUpdate: NoAction)
  usuarios       Usuario   @relation(fields: [usuario_id], references: [id], onUpdate: NoAction)

  @@id([id, acessado_em])
  @@index([paciente_id, acessado_em(sort: Desc)], map: "ix_acesso_paciente")
  @@index([usuario_id, acessado_em(sort: Desc)], map: "ix_acesso_usuario")
}

/// This table is a partition table and requires additional setup for migrations. Visit https://pris.ly/d/partition-tables for more info.
/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model auditoria_eventos {
  id             BigInt   @default(autoincrement())
  tenant_id      BigInt?
  tabela         String   @db.VarChar(120)
  registro_id    BigInt
  operacao       String   @db.Char(1)
  diff           Json
  usuario_id     BigInt?
  ip             String?  @db.Inet
  user_agent     String?
  finalidade     String?  @db.VarChar(200)
  correlation_id String?  @db.Uuid
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  @@id([id, created_at])
  @@index([correlation_id], map: "ix_audit_correlation")
  @@index([tenant_id, tabela, registro_id], map: "ix_audit_tenant_tabela_registro")
  @@index([usuario_id, created_at(sort: Desc)], map: "ix_audit_usuario")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model centros_custo {
  id                  BigInt          @id @default(autoincrement())
  tenant_id           BigInt
  codigo              String          @db.VarChar(20)
  nome                String          @db.VarChar(120)
  parent_id           BigInt?
  ativo               Boolean         @default(true)
  created_at          DateTime        @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?       @db.Timestamptz(6)
  deleted_at          DateTime?       @db.Timestamptz(6)
  centros_custo       centros_custo?  @relation("centros_custoTocentros_custo", fields: [parent_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  other_centros_custo centros_custo[] @relation("centros_custoTocentros_custo")
  tenants             Tenant          @relation(fields: [tenant_id], references: [id], onUpdate: NoAction)
  setores             setores[]

  @@unique([tenant_id, codigo], map: "uq_cc")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
