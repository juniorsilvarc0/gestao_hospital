  prioridade     Int            @default(1)
  ativo          Boolean        @default(true)
  created_at     DateTime       @default(now()) @db.Timestamptz(6)
  convenios      convenios      @relation(fields: [convenio_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  planos         planos?        @relation(fields: [plano_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tabelas_precos tabelas_precos @relation(fields: [tabela_id], references: [id], onUpdate: NoAction)
