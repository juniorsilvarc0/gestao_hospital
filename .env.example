# ──────────────────────────────────────────────────────────────────────
# HMS-BR — variáveis de ambiente (template)
# Copie para `.env`. NUNCA versione `.env`.
# Tudo roda em Docker. Hostnames internos apontam para nomes de serviço
# do compose (postgres, redis, minio, mailhog, api, ai-service).
# Exceção: VITE_*  é lido pelo navegador (no host) → usa localhost.
# ──────────────────────────────────────────────────────────────────────

# ── App ──
NODE_ENV=development
LOG_LEVEL=debug
TZ=America/Sao_Paulo

# ── Postgres ──
# `hms` é o bootstrap user (superuser) — usado APENAS pelo init.sql para
# instalar extensions e criar a role da aplicação. NÃO é usado em runtime.
POSTGRES_USER=hms
POSTGRES_PASSWORD=hms_dev_pwd
POSTGRES_DB=hms

# Role da aplicação (NOSUPERUSER, NOBYPASSRLS, com CREATEDB para shadow DB).
# RLS aplica de fato sob esta role — superusers ignoram RLS sempre.
POSTGRES_APP_USER=hms_app
POSTGRES_APP_PASSWORD=hms_app_dev_pwd

# DATABASE_URL é consumida pela api em runtime (host = nome do serviço compose).
# Aponta para a role da aplicação para que RLS aplique automaticamente.
DATABASE_URL=postgresql://hms_app:hms_app_dev_pwd@postgres:5432/hms?schema=public
SHADOW_DATABASE_URL=postgresql://hms_app:hms_app_dev_pwd@postgres:5432/hms_shadow?schema=public

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── MinIO (S3-compat) ──
MINIO_ROOT_USER=hms_minio
MINIO_ROOT_PASSWORD=hms_minio_dev_pwd
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=hms-dev
S3_ACCESS_KEY=hms_minio
S3_SECRET_KEY=hms_minio_dev_pwd
S3_FORCE_PATH_STYLE=true

# ── Mailhog (SMTP dev) ──
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=no-reply@hms.local

# ── API ──
API_PORT=3000
API_PUBLIC_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# JWT — gere segredos novos em produção: `openssl rand -base64 64`
JWT_ACCESS_SECRET=dev-access-secret-change-me-please-use-openssl-rand-base64-64
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-please-use-openssl-rand-base64-64
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# MFA — chave simétrica para cifrar `usuarios.mfa_secret` via pgcrypto.
# Em produção, gere com: `openssl rand -base64 48`. NUNCA reaproveite a JWT.
MFA_ENCRYPTION_KEY=dev-mfa-key-change-me-please-32b
MFA_TOTP_ISSUER=HMS-BR Hospital Dev

# Auditoria / correlação
AUDIT_BUFFER_SIZE=100
AUDIT_FLUSH_INTERVAL_MS=2000

# Multi-tenant (Fase 1: stub. Fase 2: RLS real via SET LOCAL.)
TENANT_DEFAULT=dev

# ── Web (Vite — lido pelo NAVEGADOR no host → localhost) ──
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000

# ── AI Service (FastAPI — desativado até Fase 11) ──
AI_SERVICE_URL=http://ai-service:8000

# ── TISS ──
TISS_VERSAO_DEFAULT=4.01.00
TISS_VALIDADOR_XSD_PATH=/app/assets/tiss-xsd

# ── Observabilidade (placeholder até Fase 13) ──
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=hms-br-api
